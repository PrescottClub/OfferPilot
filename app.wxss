/**
 * OfferPilot global design tokens
 */

page {
  min-height: 100vh;
  background: #F5F6FB;
  color: #1F2937;
  font-family: 'SF Pro Text', 'SF Pro Display', 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.page-shell {
  padding: 48rpx 32rpx 200rpx;
  box-sizing: border-box;
}

.heading-xl {
  font-size: 64rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  color: #1F2937;
}

.heading-lg {
  font-size: 48rpx;
  font-weight: 600;
  color: #1F2937;
}

.heading-md {
  font-size: 36rpx;
  font-weight: 600;
  color: #1F2937;
}

.body-text {
  font-size: 30rpx;
  font-weight: 400;
  color: #4B5563;
  line-height: 1.6;
}

.caption-text {
  font-size: 26rpx;
  color: #9CA3AF;
}

.placeholder-text {
  color: #C5CAD4;
}

.card-elevated {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 24rpx 64rpx rgba(139, 92, 246, 0.12);
}

.panel-soft {
  background: rgba(255, 255, 255, 0.72);
  border-radius: 32rpx;
  backdrop-filter: blur(34rpx);
  box-shadow: 0 18rpx 52rpx rgba(139, 92, 246, 0.1);
}

.divider-line {
  height: 1rpx;
  background: #E5E7EB;
  margin: 24rpx 0;
}

.button-primary,
.save-btn,
.primary-action {
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  background-image: linear-gradient(135deg, #8B5CF6 0%, #7C3AED 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 20rpx 50rpx rgba(139, 92, 246, 0.3);
  border: none;
}

.button-primary:active,
.save-btn:active,
.primary-action:active {
  transform: scale(0.96);
}

.button-primary::after,
.save-btn::after,
.primary-action::after {
  border: none;
}

.button-ghost,
.ghost-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  border: 2rpx solid rgba(139, 92, 246, 0.4);
  color: #8B5CF6;
  background: transparent;
  font-size: 28rpx;
  font-weight: 500;
}

.button-ghost:active,
.ghost-chip:active {
  background: rgba(139, 92, 246, 0.08);
}

.input-base,
.search-field,
.row-input,
.composer-input {
  border: none;
  background: transparent;
  color: #1F2937;
  font-size: 30rpx;
}

.input-base::placeholder,
.search-field::placeholder,
.row-input::placeholder,
.composer-input::placeholder {
  color: #C5CAD4;
}
