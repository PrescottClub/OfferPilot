page {
  min-height: 100vh;
  background-image: linear-gradient(180deg, #F5F7FB 0%, #FFFFFF 100%);
  color: #1F2937;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.container {
  padding: 32rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
  color: #1F2937;
}

.card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(229, 231, 235, 0.8);
}

.glass-card {
  background: rgba(255, 255, 255, 0.82);
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 20rpx 48rpx rgba(15, 23, 42, 0.12);
  backdrop-filter: blur(28rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.65);
}

.glass-panel {
  background: rgba(255, 255, 255, 0.88);
  border-radius: 24rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6), 0 18rpx 42rpx rgba(15, 23, 42, 0.1);
  border: 1rpx solid rgba(236, 239, 244, 0.8);
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  margin: 32rpx 0 20rpx;
  color: #1F2937;
  letter-spacing: 2rpx;
}

.btn-primary,
.save-btn,
.send-btn,
.glow-button {
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  color: #F9FAFB;
  border: none;
  border-radius: 999rpx;
  box-shadow: 0 16rpx 32rpx rgba(79, 70, 229, 0.25);
}

.btn-primary::after,
.save-btn::after,
.send-btn::after {
  border: none;
}

.input,
.frosted-input,
.search-field,
.row-input {
  background: transparent;
  border: none;
  color: #1F2937;
}

.input::placeholder,
.frosted-input::placeholder,
.search-field::placeholder,
.row-input::placeholder {
  color: rgba(17, 24, 39, 0.45);
}

.floating-chip {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(79, 70, 229, 0.12);
  color: #4F46E5;
  border: 1rpx solid rgba(99, 102, 241, 0.28);
}

.subtitle {
  color: rgba(17, 24, 39, 0.6);
}

.text-light {
  color: rgba(17, 24, 39, 0.45);
}
