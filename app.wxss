page {
  background: #f6f7f9;
  color: #1f2937;
}

.container {
  padding: 16rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 24rpx 0 16rpx;
}

.btn-primary {
  background: #07c160;
  color: #fff;
  border: none;
}

.input {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
}

