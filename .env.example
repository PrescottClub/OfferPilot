# ======================================
# Django Settings
# ======================================
# 生产环境请使用强密钥，可通过以下命令生成：
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=django-insecure-dev-key-change-in-production-!@#$%^&*()

# 开发模式开关（生产环境必须设置为 False）
DEBUG=True

# 允许的主机列表
# 本地开发: localhost,127.0.0.1
# 微信云托管: 添加云托管提供的域名，如 your-service.weixincloud.run
ALLOWED_HOSTS=localhost,127.0.0.1

# ======================================
# Database Configuration (MySQL)
# ======================================
# 本地开发配置
DB_NAME=offerpilot
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# 微信云托管部署说明:
# 云托管会自动注入以下环境变量（如使用云托管 MySQL）：
# - MYSQL_ADDRESS (数据库地址)
# - MYSQL_USERNAME (数据库用户名)
# - MYSQL_PASSWORD (数据库密码)
# - MYSQL_DATABASE (数据库名称)
# 部署时可通过云托管控制台配置，或在 settings.py 中添加环境变量判断逻辑

# ======================================
# WeChat Mini Program Configuration
# ======================================
# 微信小程序 AppID (已有: wxf3c2565e0e00d81a)
WECHAT_APP_ID=wxf3c2565e0e00d81a

# 微信小程序 AppSecret (从微信公众平台获取)
# 路径: 微信公众平台 > 开发 > 开发管理 > 开发设置 > 开发者密钥
WECHAT_APP_SECRET=

# ======================================
# CORS Configuration
# ======================================
# 跨域资源共享配置
# 本地开发可添加: http://localhost:8000,http://127.0.0.1:8000
# 微信小程序必须包含: https://servicewechat.com
# 微信云托管需要添加云托管域名
CORS_ALLOWED_ORIGINS=https://servicewechat.com

# ======================================
# Additional Settings for Production
# ======================================
# 静态文件存储（生产环境推荐使用云存储）
# STATIC_ROOT=/www/staticfiles
# MEDIA_ROOT=/www/media

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# ======================================
# 快速开始指南
# ======================================
# 1. 复制此文件: cp .env.example .env
# 2. 编辑 .env 文件，填入实际配置
# 3. 安装依赖: uv pip install -r requirements.txt
# 4. 创建数据库: mysql -u root -p -e "CREATE DATABASE offerpilot CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;"
# 5. 运行迁移: python3 index.py migrate
# 6. 创建缓存表: python3 index.py createcache
# 7. 创建管理员: python3 index.py createsuperuser
# 8. 启动服务: python3 index.py
