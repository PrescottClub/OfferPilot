.row-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.row-label {
  font-size: 26rpx;
  color: rgba(17, 24, 39, 0.6);
}

.row-input {
  border: none;
  font-size: 30rpx;
  color: #111827;
  background: transparent;
  padding: 0;
}

.row-input::placeholder {
  color: rgba(17, 24, 39, 0.38);
}

.row-input:focus {
  outline: none;
}

.row-value {
  font-size: 30rpx;
  color: #111827;
}

.placeholder {
  color: rgba(17, 24, 39, 0.38);
}

