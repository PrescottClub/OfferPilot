.sheet-option .wx-checkbox-input {
  border-color: #8B5CF6;
}

.sheet-option .wx-checkbox-input.wx-checkbox-input-checked {
  background-color: #8B5CF6;
  border-color: #8B5CF6;
}

.actions {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  justify-content: center;
}

.save-btn {
  width: 100%;
}
