.profile-screen {
  min-height: 100vh;
  padding: 0 32rpx 120rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #F4F6FA 0%, #E6E9F2 100%);
  color: #111827;
}

.profile-hero {
  padding-top: 48rpx;
  display: flex;
  justify-content: center;
}

.hero-glass {
  position: relative;
  width: 100%;
  max-width: 680rpx;
  border-radius: 36rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.3);
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.18);
  border: 1rpx solid rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(32rpx);
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(120% 120% at 14% 20%, rgba(77, 223, 247, 0.32) 0%, rgba(255, 255, 255, 0) 65%),
    radial-gradient(110% 110% at 86% 18%, rgba(79, 70, 229, 0.35) 0%, rgba(255, 255, 255, 0) 70%);
  filter: blur(18rpx);
  opacity: 0.85;
}

.hero-content {
  position: relative;
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 48rpx 48rpx 56rpx;
}

.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: linear-gradient(135deg, rgba(77, 223, 247, 0.55), rgba(79, 70, 229, 0.48));
  box-shadow: 0 24rpx 42rpx rgba(79, 70, 229, 0.22);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.hero-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-name {
  font-size: 44rpx;
  font-weight: 600;
  color: #0B1D3B;
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(17, 24, 39, 0.65);
}

.form-section {
  margin-top: 48rpx;
  padding: 32rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.85);
  box-shadow: 0 16rpx 44rpx rgba(15, 23, 42, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.section-header {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2937;
  margin-bottom: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 22rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  gap: 20rpx;
}

.info-row + .info-row {
  margin-top: 14rpx;
}

.row-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  background: rgba(79, 70, 229, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  background-size: 26rpx;
  background-repeat: no-repeat;
  background-position: center;
}

