  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 40 28'><rect width='40' height='28' fill='%23B22234'/><g fill='%23FFFFFF'><rect y='4' width='40' height='4'/><rect y='12' width='40' height='4'/><rect y='20' width='40' height='4'/></g><rect width='16' height='12' fill='%23005490'/><circle cx='5' cy='4' r='1.5' fill='%23FFFFFF'/><circle cx='9.5' cy='6.5' r='1.5' fill='%23FFFFFF'/><circle cx='13' cy='4' r='1.5' fill='%23FFFFFF'/></svg>");
