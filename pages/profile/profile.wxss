.regions-sheet {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(244, 246, 250, 0.95);
  border: 1rpx solid rgba(226, 232, 240, 0.85);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.sheet-title {
  font-size: 26rpx;
  color: rgba(17, 24, 39, 0.7);
}

.sheet-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
  font-size: 28rpx;
  color: #111827;
}

.actions {
  margin-top: 36rpx;
  display: flex;
  justify-content: center;
}

.save-btn {
  width: 100%;
  max-width: 640rpx;
  border-radius: 999rpx;
  background: #4F46E5;
  color: #F9FAFB;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 0;
  box-shadow: 0 18rpx 40rpx rgba(79, 70, 229, 0.35);
}

.save-btn::after {
  border: none;
}

.checkbox .wx-checkbox-input {
  border-color: #4F46E5;
}
