.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e5e7eb;
}

.form .row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.form .row:last-child {
  border-bottom: none;
}

.label {
  width: 220rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.value {
  flex: 1;
}

.tag {
  margin-right: 24rpx;
}

.expand-btn {
  background: #f6f7f9;
  color: #111827;
  margin-left: auto;
}

.regions-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.selected-regions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.pill {
  padding: 6rpx 14rpx;
  background: #eef2ff;
  color: #374151;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.placeholder {
  color: #9ca3af;
}
