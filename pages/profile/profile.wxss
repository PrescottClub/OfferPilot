.sheet-option .wx-checkbox-input {
  border-color: #8B5CF6;
}

.sheet-option .wx-checkbox-input.wx-checkbox-input-checked {
  background-color: #8B5CF6;
  border-color: #8B5CF6;
}

.actions {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  justify-content: center;
}

.save-btn {
  width: 100%;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
}

.save-btn.is-saving {
  opacity: 0.6;
}

.save-btn.is-saved {
  animation: pulse-glow 620ms ease;
}

.profile-skeleton {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.skeleton-hero {
  height: 220rpx;
  border-radius: 36rpx;
}

.skeleton-form-title {
  width: 220rpx;
}

.skeleton-form-caption {
  width: 360rpx;
}

.skeleton-form {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-label {
  width: 120rpx;
}

.skeleton-input {
  width: 100%;
}

.skeleton-button {
  height: 96rpx;
  border-radius: 28rpx;
}
