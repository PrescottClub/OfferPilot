.profile-screen {
  min-height: 100vh;
  padding-bottom: 200rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  align-items: center;
  position: relative;
}

.hero-card {
  position: relative;
  overflow: hidden;
  width: 100%;
  max-width: 720rpx;
  padding: 40rpx;
}

.hero-gradient {
  position: absolute;
  inset: 0;
  background: radial-gradient(140% 140% at 18% 24%, rgba(139, 92, 246, 0.22) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(140% 140% at 82% 18%, rgba(56, 189, 248, 0.18) 0%, rgba(255, 255, 255, 0) 70%);
  opacity: 0.9;
}

.hero-content {
  position: relative;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.identity-orb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.4), rgba(56, 189, 248, 0.35));
  box-shadow: 0 28rpx 56rpx rgba(139, 92, 246, 0.25);
}

.hero-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #1F2937;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hero-name {
  color: #1F2937;
}

.hero-status {
  font-size: 28rpx;
  color: #9CA3AF;
}

.hero-subtitle {
  color: #6B7280;
  max-width: 440rpx;
}

.form-section {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 32rpx;
}

.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.save-hint {
  color: #8B5CF6;
}

.row-input {
  font-size: 32rpx;
  font-weight: 500;
}

.row-value {
  font-size: 32rpx;
  color: #1F2937;
}

.form-section .divider-line {
  margin: 0;
}

.regions-sheet {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 420rpx;
  overflow-y: auto;
  z-index: 9;
}

.sheet-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #4B5563;
}

.sheet-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: #1F2937;
}

.sheet-option checkbox {
  transform: scale(0.9);
}

.sheet-flag {
  width: 44rpx;
  height: 32rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  box-shadow: 0 6rpx 12rpx rgba(15, 23, 42, 0.18);
}

.sheet-label {
  flex: 1;
}

