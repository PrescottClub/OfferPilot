.chat-page {
  position: relative;
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.chat-overlay {
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(100% 100% at 15% 25%, rgba(99, 102, 241, 0.12) 0%, rgba(255, 255, 255, 0) 70%),
    radial-gradient(120% 120% at 80% 20%, rgba(79, 70, 229, 0.1) 0%, rgba(255, 255, 255, 0) 75%);
  opacity: 0.8;
  pointer-events: none;
}

.chat-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 180rpx;
}

.welcome-card {
  position: relative;
}

.welcome-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.logo-mark {
  width: 96rpx;
  height: 96rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #4F46E5, #6366F1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #F9FAFB;
  font-weight: 700;
  font-size: 32rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 16rpx 32rpx rgba(99, 102, 241, 0.35);
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 600;
}

.welcome-subtitle {
  margin-top: 6rpx;
  font-size: 26rpx;
}

.welcome-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(229, 231, 235, 0.8);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7), 0 16rpx 36rpx rgba(15, 23, 42, 0.06);
}

.msg {
  display: flex;
}

.msg .bubble {
  max-width: 82%;
  padding: 26rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(229, 231, 235, 0.8);
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.08);
}

.msg.bot {
  justify-content: flex-start;
}

.msg.bot .bubble {
  background: rgba(248, 249, 255, 0.96);
  border: 1rpx solid rgba(99, 102, 241, 0.2);
}

.msg.me {
  justify-content: flex-end;
}

.msg.me .bubble {
  background: rgba(79, 70, 229, 0.12);
  border: 1rpx solid rgba(79, 70, 229, 0.28);
}

.msg-role {
  display: inline-flex;
  padding: 4rpx 18rpx;
  margin-bottom: 10rpx;
  border-radius: 999rpx;
  background: rgba(79, 70, 229, 0.15);
  font-size: 22rpx;
  color: #4F46E5;
  letter-spacing: 3rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #1F2937;
  word-break: break-word;
}

.composer {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(229, 231, 235, 0.8);
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.08);
  z-index: 10;
}

.composer-input {
  flex: 1;
}

.composer-input:focus {
  outline: none;
}

.send-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
