.chat-page {
  position: relative;
  min-height: 100vh;
  padding: 40rpx 32rpx 160rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.chat-overlay {
  position: absolute;
  inset: 0;
  background: radial-gradient(120% 120% at 16% 20%, rgba(139, 92, 246, 0.14) 0%, rgba(255, 255, 255, 0) 70%),
    radial-gradient(120% 140% at 82% 10%, rgba(99, 102, 241, 0.12) 0%, rgba(255, 255, 255, 0) 68%);
  pointer-events: none;
  z-index: 0;
}

.chat-stack {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.welcome-card {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.welcome-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.logo-mark {
  width: 104rpx;
  height: 104rpx;
  border-radius: 52rpx;
  background-image: linear-gradient(135deg, #8B5CF6, #7C3AED);
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 24rpx 48rpx rgba(124, 58, 237, 0.3);
}

.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
}

.msg {
  display: flex;
}

.msg.bot {
  justify-content: flex-start;
}

.msg.me {
  justify-content: flex-end;
}

.bubble {
  position: relative;
  max-width: 82%;
  padding: 26rpx 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 32rpx rgba(15, 23, 42, 0.08);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.msg.bot .bubble {
  background: #F4F2FF;
  color: #1F2937;
}

.msg.me .bubble {
  background-image: linear-gradient(135deg, #8B5CF6, #7C3AED);
  color: #FFFFFF;
}

.bubble::after {
  content: '';
  position: absolute;
  top: 36rpx;
  width: 0;
  height: 0;
}

.msg.bot .bubble::after {
  left: -20rpx;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-right: 20rpx solid #F4F2FF;
}

.msg.me .bubble::after {
  right: -20rpx;
  border-top: 16rpx solid transparent;
  border-bottom: 16rpx solid transparent;
  border-left: 20rpx solid #7C3AED;
}

.msg-text {
  font-size: 30rpx;
  letter-spacing: 0.2rpx;
}

.msg-text.bot-text {
  color: #1F2937;
}

.msg-text.me-text {
  color: #FFFFFF;
}

.composer-panel {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  border-radius: 32rpx;
  background: #FFFFFF;
  box-shadow: 0 18rpx 36rpx rgba(15, 23, 42, 0.08);
  z-index: 10;
}

.composer-input {
  flex: 1;
}

.send-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  border: none;
  background: #E7E9F3;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease, transform 0.2s ease;
}

.send-btn::after {
  border: none;
}

.send-btn:active {
  transform: scale(0.95);
}

.send-btn.is-active {
  background-image: linear-gradient(135deg, #8B5CF6, #7C3AED);
  box-shadow: 0 14rpx 36rpx rgba(139, 92, 246, 0.35);
}

.send-glyph {
  width: 40rpx;
  height: 40rpx;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' fill='none' stroke='%238B5CF6' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><path d='M4 4l24 12-24 12 6-12-6-12z'/></svg>");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  transition: transform 0.2s ease;
}

.send-btn.is-active .send-glyph {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' fill='none' stroke='%23FFFFFF' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><path d='M4 4l24 12-24 12 6-12-6-12z'/></svg>");
}
