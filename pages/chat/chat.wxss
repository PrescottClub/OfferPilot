.chat-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.history {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.msg {
  display: flex;
  margin: 12rpx 0;
}

.msg .bubble {
  max-width: 72%;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.4;
}

.msg.me {
  justify-content: flex-end;
}

.msg.me .bubble {
  background: #07c160;
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.msg.bot {
  justify-content: flex-start;
}

.msg.bot .bubble {
  background: #ffffff;
  color: #1f2937;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

.composer {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  padding: 12rpx 16rpx 24rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
  box-shadow: 0 -6rpx 18rpx rgba(0,0,0,0.06);
}

.composer-input {
  flex: 1;
  background: #f6f7f9;
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
}

.composer-send {
  padding: 10rpx 20rpx;
}

