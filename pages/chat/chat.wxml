<view class="chat-page page-shell">
  <view class="chat-overlay"></view>
  <view class="chat-stack">
    <view class="welcome-card card-elevated">
      <view class="welcome-top">
        <view class="logo-mark">OP</view>
        <view class="welcome-copy">
          <view class="heading-lg">OfferPilot 智能顾问</view>
          <view class="caption-text">欢迎回来，随时向我咨询你的留学申请计划。</view>
        </view>
      </view>
      <view class="quick-actions">
        <block wx:for="{{quickPrompts}}" wx:key="*this">
          <view class="ghost-chip" data-value="{{item}}" bindtap="onQuickSelect">{{item}}</view>
        </block>
      </view>
    </view>

    <scroll-view class="history card-elevated" scroll-y="true" enable-flex="true" scroll-into-view="{{scrollIntoView}}">
      <block wx:for="{{messages}}" wx:key="id">
        <view class="msg {{item.role}}" id="msg-{{item.id}}">
          <view class="bubble">
            <view class="msg-text {{item.role}}-text">{{item.text}}</view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>

  <view class="composer-panel">
    <input
      class="composer-input input-base"
      placeholder="请输入你想咨询的内容"
      value="{{draft}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSend"
    />
    <button class="send-btn {{draft ? 'is-active' : ''}}" size="mini" bindtap="onSend">
      <view class="send-glyph"></view>
    </button>
  </view>
</view>
