.tools-page {
  display: flex;
  justify-content: center;
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.08) 0%, rgba(245, 246, 251, 0.4) 35%, rgba(245, 246, 251, 1) 100%);
}

.tools-inner {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.tools-header {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 28rpx;
  background: #F4F2FF;
  box-shadow: none;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' fill='none' stroke='%238B5CF6' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='6'/><path d='M16 16l4 4'/></svg>");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 32rpx;
}

.tool-card {
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  align-items: center;
  text-align: center;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.tool-card:active {
  transform: translateY(6rpx);
  box-shadow: 0 18rpx 40rpx rgba(139, 92, 246, 0.18);
}

.tool-icon-cap {
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tool-icon-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.18) 0%, rgba(139, 92, 246, 0.04) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tool-icon-ring::after {
  content: '';
  position: absolute;
  inset: 16rpx;
  border-radius: 28rpx;
  background: #F5F1FF;
}

.tool-duo {
  position: relative;
  z-index: 1;
  width: 64rpx;
  height: 64rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.tool-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: center;
}

.tool-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1F2937;
}

.tool-desc {
  color: #6B7280;
  line-height: 1.5;
}

.empty-state {
  grid-column: 1 / span 2;
  padding: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.tool-duo.icon-speaking {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' fill='none' stroke='%238B5CF6' stroke-width='2.4' stroke-linecap='round' stroke-linejoin='round'><rect x='10' y='6' width='12' height='16' rx='6'/><path d='M16 22v4'/><path d='M11 26h10'/></svg>");
}

.tool-duo.icon-essay {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' fill='none' stroke='%238B5CF6' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><rect x='9' y='6' width='14' height='20' rx='3'/><path d='M12 12h8'/><path d='M12 16h8'/><path d='M12 20h6'/></svg>");
}

.tool-duo.icon-community {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' fill='none' stroke='%238B5CF6' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><circle cx='12' cy='13' r='5'/><circle cx='20' cy='13' r='5'/><path d='M4 26c1.6-4.6 4.8-7 8-7s6.4 2.4 8 7'/><path d='M16 22c1.6-4.6 4.8-7 8-7s6.4 2.4 8 7'/></svg>");
}

