.tools-dashboard {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F7FB 0%, #E5E7EF 100%);
  padding: 48rpx 32rpx 140rpx;
  box-sizing: border-box;
  color: #1F2937;
}

.dashboard-inner {
  max-width: 700rpx;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.dashboard-header {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dashboard-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #111827;
}

.dashboard-subtitle {
  font-size: 26rpx;
  color: rgba(55, 65, 81, 0.78);
  line-height: 1.5;
}

.search-row {
  display: flex;
}

.glass-input,
.search-bar {
  width: 100%;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(30rpx);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.65), 0 24rpx 34rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  display: flex;
  align-items: center;
  padding: 18rpx 24rpx;
  box-sizing: border-box;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  background-image: url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSIyMCIgaGVpZ2h0PSIyMCIgZmlsbD0ibm9uZSIgc3Ryb2tlPSIjNEY0NkU1IiBzdHJva2Utd2lkdGg9IjIiIHN0cm9rZS1saW5lY2FwPSJyb3VuZCIgc3Ryb2tlLWxpbmVqb2luPSJyb3VuZCI+PGNpcmNsZSBjeD0iOSIgY3k9IjkiIHI9IjYiLz48cGF0aCBkPSJNMTQgMTRsNCA0Ii8+PC9zdmc+');
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  margin-right: 16rpx;
  opacity: 0.9;
}

.search-field {
  flex: 1;
  border: none;
  font-size: 28rpx;
  color: #1F2937;
  background: transparent;
}

.search-field::placeholder {
  color: rgba(55, 65, 81, 0.55);
}

.search-field:focus {
  outline: none;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  grid-template-rows: repeat(3, minmax(0, 1fr));
  gap: 32rpx;
}

.tool-card {
  min-height: 240rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(34rpx);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.65), 0 22rpx 40rpx rgba(79, 70, 229, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.85);
  padding: 36rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.tool-card:active {
  transform: scale(0.98);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7), 0 18rpx 30rpx rgba(79, 70, 229, 0.18);
}

.tool-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: rgba(79, 70, 229, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.glyph {
  width: 96rpx;
  height: 96rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.icon-speaking {
  background-image: url('data:image/svg+xml;base64,');
}

.icon-essay {
  background-image: url('data:image/svg+xml;base64,');
}

.icon-community {
  background-image: url('data:image/svg+xml;base64,');
}

.icon-visa {
  background-image: url('data:image/svg+xml;base64,');
}

.icon-interview {
  background-image: url('data:image/svg+xml;base64,');
}

.icon-database {
  background-image: url('data:image/svg+xml;base64,');
}

.tool-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1F2937;
  text-align: center;
}

.empty-state {
  grid-column: 1 / span 2;
  justify-content: center;
  color: rgba(55, 65, 81, 0.65);
}

.empty-state text {
  font-size: 28rpx;
}

