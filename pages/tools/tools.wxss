.tools-page {
  display: flex;
  justify-content: center;
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.08) 0%, rgba(245, 246, 251, 0.4) 35%, rgba(245, 246, 251, 1) 100%);
}

.tools-inner {
  width: 100%;
  max-width: 720rpx;
  display: flex;
  flex-direction: column;
  gap: 48rpx;
}

.tools-header {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 28rpx;
  background: #F4F2FF;
  box-shadow: none;
}

.search-icon {
  width: 40rpx;
  height: 40rpx;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' fill='none' stroke='%238B5CF6' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='6'/><path d='M16 16l4 4'/></svg>");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 32rpx;
}

.empty-state {
  grid-column: 1 / span 2;
  padding: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}
