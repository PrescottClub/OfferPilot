.tool-duo.icon-interview {
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' fill='none' stroke='%238B5CF6' stroke-width='2.2' stroke-linecap='round' stroke-linejoin='round'><circle cx='11' cy='11' r='5'/><circle cx='21' cy='11' r='5'/><path d='M4 24h10l4 6 4-6h10'/></svg>");
