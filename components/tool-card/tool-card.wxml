<view class="tool-card card-elevated" bindtap="handleTap">
  <view class="tool-icon-cap">
    <view class="tool-icon-ring">
      <view class="tool-duo {{icon}}"></view>
    </view>
  </view>
  <view class="tool-meta">
    <view class="tool-title heading-md">{{name}}</view>
    <view class="tool-desc caption-text">{{description}}</view>
    <slot></slot>
  </view>
</view>
